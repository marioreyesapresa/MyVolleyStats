# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copia este archivo a ".env" y rellena los valores reales.
# NUNCA subas el archivo ".env" al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# Django Secret Key (genera una nueva en: https://djecrety.ir/ o con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=cambia-esto-por-una-clave-segura-de-50-caracteres

# Modo debug: True en desarrollo, False SIEMPRE en producción (Cloud Run).
DJANGO_DEBUG=True

# Hosts permitidos (separados por coma, sin espacios ni esquema).
# Ejemplo local:      ALLOWED_HOSTS=127.0.0.1,localhost
# Ejemplo Cloud Run:  ALLOWED_HOSTS=my-volley-stats-xxxxxxxxxx-ew.a.run.app,tudominio.com
ALLOWED_HOSTS=127.0.0.1,localhost

# Orígenes de confianza para CSRF (necesarios en producción tras HTTPS).
# Deben incluir el esquema https:// y separarse por coma. Vacío en local.
# Ejemplo: CSRF_TRUSTED_ORIGINS=https://my-volley-stats-xxxxxxxxxx-ew.a.run.app,https://tudominio.com
CSRF_TRUSTED_ORIGINS=

# Base de datos.
# - Sin definir (o vacía): usa SQLite local (db.sqlite3). Ideal para desarrollo.
# - En producción, cadena de conexión de Neon (PostgreSQL) en formato URL.
#   Cópiala del dashboard de Neon → Connection string → "Pooled connection".
#   DATABASE_URL=postgres://usuario:contraseña@ep-xxxx-pooler.eu-central-1.aws.neon.tech/voley_stats?sslmode=require
DATABASE_URL=

# Correo (recuperación de contraseña). En local deja el backend por defecto (consola).
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.tuproveedor.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=usuario
# EMAIL_HOST_PASSWORD=contraseña
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@tudominio.com
